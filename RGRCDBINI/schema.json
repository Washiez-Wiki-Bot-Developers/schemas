{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Roblox Group Rank Changes Detection Bot Inter-notification Interchange",
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,11}$",
      "description": "Roblox Group ID string."
    },
    "uid": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the payload transaction."
    },
    "users_cnt": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "The number of User changes notifying to others."
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "pattern": "^[1-9][0-9]{0,11}$"
          },
          "role_id_to": {
            "type": "string",
            "pattern": "^[1-9][0-9]{4,11}$"
          },
          "role_id_from": {
            "type": "string",
            "pattern": "^[1-9][0-9]{4,11}$"
          },
          "source": {
            "type": "string",
            "description": "Name for the bot notifying others. Bots replace with 'third-party bots' when empty."
          },
          "ts": {
            "type": "integer",
            "minimum": 0,
            "description": "Unix Epoch timestamp when discovered."
          }
        },
        "required": ["user_id", "role_id_to", "role_id_from"]
      }
    },
    "source": {
      "type": "string"
    },
    "ts": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix Epoch timestamp at the time of reporting."
    }
  },
  "required": ["group_id", "uid", "users_cnt", "users", "ts"]
}
